# --- AI Studio (Direct) ---
GEMINI_API_KEY=your_aistudio_api_key_here

# --- Vertex AI (Google Cloud) ---
GOOGLE_CLOUD_PROJECT=your_gcp_project_id_here
GOOGLE_CLOUD_LOCATION=us-central1

# --- Legacy Proxy Configuration (Archived) ---
# Set to 'true' only if you are using the legacy local proxy
ENABLE_LEGACY_PROXY=false
# LEGACY_GEMINI_API_URL=http://localhost:7861/antigravity
# LEGACY_GEMINI_AUTH_TOKEN=your_legacy_password_here

# --- Core Defaults ---
# The default provider route order (AI Studio -> Vertex)
DEFAULT_PROVIDERS=aistudio,vertex
# DEFAULT_MODEL=gemini-3-flash
# DEFAULT_THINKING_LEVEL=HIGH

# --- System ---
# WORKSPACE_BASE=./workspace
# DEBUG_MODE=true
# HEADLESS_MODE=true
